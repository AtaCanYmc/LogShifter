# GitHub Adapter Configuration
# GITHUB_TOKEN is required for pushing commits via GitHub API or SSH/HTTPS authentication.
LOGSHIFT_GITHUB_TOKEN=your_github_personal_access_token_here
LOGSHIFT_GITHUB_USERNAME=your_github_username_here
LOGSHIFT_GITHUB_EMAIL=your_email@example.com

# Supabase Source Configuration (for future log extraction)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
